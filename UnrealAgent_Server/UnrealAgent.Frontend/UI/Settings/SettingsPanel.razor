@if (bIsVisible)
{
    <div class="fixed inset-0 bg-black/60 z-50 flex items-center justify-center" @onclick="OnClose">
        <div class="bg-[#1a1a1a] border border-[#333] rounded-lg w-[420px] max-h-[80vh] overflow-y-auto shadow-2xl shadow-black/50" @onclick:stopPropagation>
            <!-- 헤더 -->
            <div class="flex items-center justify-between px-5 py-4 border-b border-[#333]">
                <h2 class="text-[15px] font-semibold text-[#e0e0e0]">설정</h2>
                <button @onclick="OnClose" class="size-7 rounded flex items-center justify-center text-[#888] hover:text-white hover:bg-[#333] transition-colors">
                    <span class="material-symbols-outlined text-[18px]">close</span>
                </button>
            </div>

            <div class="p-5 flex flex-col gap-5">
                <!-- 활성 인증 -->
                <div class="flex flex-col gap-2.5">
                    <div class="text-[10px] font-bold text-[#666] uppercase tracking-widest">활성 인증</div>
                    <div class="flex items-center gap-2.5 px-3 py-2.5 rounded border border-[#333] text-left w-full">
                        <span class="text-[13px] font-medium text-[#ccc]">API Key</span>
                        @if (Auth.IsApiKeyConfigured())
                        {
                            <span class="ml-auto text-[10px] px-2 py-0.5 rounded bg-[#4ba96c]/10 text-[#4ba96c] border border-[#4ba96c]/20 font-bold">설정됨</span>
                        }
                        else
                        {
                            <span class="ml-auto text-[10px] px-2 py-0.5 rounded bg-[#e05e5e]/10 text-[#e05e5e] border border-[#e05e5e]/20 font-bold">미설정</span>
                        }
                    </div>
                </div>

                <!-- 인증 설정 -->
                <div class="flex flex-col gap-2.5">
                    <div class="text-[10px] font-bold text-[#666] uppercase tracking-widest">인증 설정</div>

                    <div class="flex flex-col gap-3">
                        <p class="text-[13px] text-[#888] leading-relaxed">
                            Anthropic API Key를 입력해주세요. 키는 로컬에 안전하게 저장됩니다.
                        </p>
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[13px] text-[#888]">API Key</label>
                            <input type="password"
                                   @bind="ApiKeyInput"
                                   placeholder="sk-ant-..."
                                   class="bg-[#151515] border border-[#333] rounded px-3 py-2.5 text-sm font-mono text-[#ccc] outline-none focus:border-[#0070e0]/50 focus:ring-1 focus:ring-[#0070e0]/20 transition-all placeholder:text-[#555]" />
                        </div>
                        <div class="flex gap-2">
                            <button @onclick="SaveApiKey" class="px-4 py-2 bg-gradient-to-b from-[#0070e0] to-[#005bb5] text-white text-sm font-medium rounded transition-colors shadow-[inset_0_1px_0_rgba(255,255,255,0.2)] hover:from-[#0080ff] hover:to-[#006bd6]">
                                저장
                            </button>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(StatusMessage))
                    {
                        <div class="text-[11px] @StatusCss mt-1">@StatusMessage</div>
                    }
                </div>
            </div>
        </div>
    </div>
}