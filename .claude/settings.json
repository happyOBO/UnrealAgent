{
  "permissions": {
    "allow": [
      "Bash(claude -p --system-prompt-file /tmp/sp.txt --model claude-haiku-4-5-20251001)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
