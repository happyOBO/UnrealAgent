
<header class="flex items-center justify-between whitespace-nowrap border-b border-[#2a2a2a] bg-[#1a1a1a] px-5 py-2 shrink-0 z-30 shadow-md">
    <!-- 로고 -->
    <div class="flex items-center gap-3">
        <div class="size-7 flex items-center justify-center rounded bg-gradient-to-b from-[#444] to-[#222] border border-[#555] shadow-inner shadow-[0_0_10px_rgba(0,112,224,0.25)] relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-tr from-white/10 to-transparent opacity-50"></div>
            <!-- 엔진(3D 큐브) + AI(스파크) 결합 마크 -->
            <LogoMark Class="size-4 relative z-10 text-white/90 drop-shadow-md" />
        </div>
        <h2 class="text-sm font-semibold text-[#e0e0e0] tracking-tight uppercase opacity-90">
            UnrealAgent
        </h2>
    </div>
    
    <!-- 연결 상태 + 설정 -->
    <div class="flex items-center gap-4">
        <!-- 연결 상태 점 (App.razor의 JS가 Blazor 회로 상태에 따라 색/툴팁 갱신) -->
        <div class="relative group flex items-center">
            <span id="conn-dot" class="size-2 rounded-full bg-emerald-500 shadow-[0_0_6px_rgba(16,185,129,0.6)] transition-colors"></span>
            <div class="absolute top-full right-0 mt-2 w-32 p-2.5 bg-[#151515]/90 backdrop-blur-md border border-[#333] rounded shadow-xl text-[10px] z-50 pointer-events-none opacity-0 group-hover:opacity-100 transition-all duration-200">
                <div id="conn-dot-label" class="text-[#e0e0e0] font-medium leading-tight text-center">연결됨</div>
                <div class="absolute top-[-5px] right-1.5 w-2.5 h-2.5 bg-[#151515]/90 border-t border-l border-[#333] rotate-45"></div>
            </div>
        </div>
        <div class="h-4 w-px bg-[#333]"></div>
        <div class="flex items-center gap-1">
            <!-- 세션 복원 -->
            <button @onclick="OnRestoreContext" disabled="@(!bCanRestore)"
                    class="relative group flex items-center justify-center size-7 rounded transition-colors @(bCanRestore ? "hover:bg-[#2a2a2a] text-[#888] hover:text-[#ddd]" : "text-[#444] cursor-not-allowed")">
                <span class="material-symbols-outlined text-[18px]">history</span>
                <div class="absolute top-full right-0 mt-2 w-44 p-2.5 bg-[#151515]/90 backdrop-blur-md border border-[#333] rounded shadow-xl text-[10px] z-50 pointer-events-none opacity-0 group-hover:opacity-100 transition-all duration-200">
                    <div class="text-[#e0e0e0] font-medium leading-tight text-center">이전 세션 복원</div>
                    <div class="absolute top-[-5px] right-2.5 w-2.5 h-2.5 bg-[#151515]/90 border-t border-l border-[#333] rotate-45"></div>
                </div>
            </button>

            <!-- 새 세션 -->
            <button @onclick="OnNewSession"
                    class="relative group flex items-center justify-center size-7 rounded hover:bg-[#2a2a2a] transition-colors text-[#888] hover:text-[#ddd]">
                <span class="material-symbols-outlined text-[18px]">restart_alt</span>
                <div class="absolute top-full right-0 mt-2 w-44 p-2.5 bg-[#151515]/90 backdrop-blur-md border border-[#333] rounded shadow-xl text-[10px] z-50 pointer-events-none opacity-0 group-hover:opacity-100 transition-all duration-200">
                    <div class="text-[#e0e0e0] font-medium leading-tight text-center">새 세션 (대화 초기화)</div>
                    <div class="absolute top-[-5px] right-2.5 w-2.5 h-2.5 bg-[#151515]/90 border-t border-l border-[#333] rotate-45"></div>
                </div>
            </button>

            <!-- OAuth 설정 창 -->
            <button @onclick="OnSettingsClick"
                    class="relative group flex items-center justify-center size-7 rounded hover:bg-[#2a2a2a] transition-colors text-[#888] hover:text-[#ddd]">
                <span class="material-symbols-outlined text-[18px]">settings</span>
                <div class="absolute top-full right-0 mt-2 w-44 p-2.5 bg-[#151515]/90 backdrop-blur-md border border-[#333] rounded shadow-xl text-[10px] z-50 pointer-events-none opacity-0 group-hover:opacity-100 transition-all duration-200">
                    <div class="text-[#e0e0e0] font-medium leading-tight text-center">OAuth 인증 관리</div>
                    <div class="absolute top-[-5px] right-2.5 w-2.5 h-2.5 bg-[#151515]/90 border-t border-l border-[#333] rotate-45"></div>
                </div>
            </button>
        </div>
    </div>
</header>